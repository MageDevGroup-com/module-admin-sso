<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!-- Open/closed seam: provider plugins di-merge their preset into `presets`. -->
    <type name="MageDevGroup\AdminSso\Model\PresetRegistry">
        <arguments>
            <argument name="presets" xsi:type="array"/>
        </arguments>
    </type>
    <!-- Persist the one-time OIDC authorization state in the admin session. -->
    <preference for="MageDevGroup\SsoCore\Api\AuthorizationStateStorageInterface"
                type="MageDevGroup\AdminSso\Model\Session\AuthorizationStateStorage"/>
    <!-- Enforce-SSO: block native admin login (break-glass stays open) when enforced. -->
    <type name="Magento\Backend\Model\Auth">
        <plugin name="magedevgroup_admin_sso_enforce"
                type="MageDevGroup\AdminSso\Plugin\Backend\EnforceSso"/>
    </type>
</config>
