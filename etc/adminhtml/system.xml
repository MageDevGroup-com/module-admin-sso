<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="magedevgroup" translate="label" sortOrder="400">
            <label>MageDevGroup</label>
        </tab>
        <section id="magedevgroup_admin_sso" translate="label" type="text" sortOrder="10"
                 showInDefault="1" showInWebsite="0" showInStore="0">
            <class>separator-top</class>
            <label>Admin SSO</label>
            <tab>magedevgroup</tab>
            <resource>MageDevGroup_AdminSso::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>General</label>
                <field id="enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Enable Admin SSO</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="active_provider" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Identity Provider</label>
                    <source_model>MageDevGroup\AdminSso\Model\Config\Source\ActiveProvider</source_model>
                    <comment>The list is populated by installed provider plugins (e.g. admin-sso-okta).</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="client_id" translate="label" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Client ID</label>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="client_secret" translate="label" type="obscure" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Client Secret</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="enforce_sso" translate="label comment" type="select" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Enforce SSO</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Disables the native admin login form. Keep break-glass on to stay recoverable.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="break_glass" translate="label comment" type="select" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Allow Break-Glass Login</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Keeps a guarded local-admin login path available while SSO is enforced.</comment>
                    <depends>
                        <field id="enforce_sso">1</field>
                    </depends>
                </field>
                <field id="group_role_map" translate="label comment" type="textarea" sortOrder="70"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Group to Role Map</label>
                    <comment><![CDATA[One rule per line as <code>idp_group=role_id</code>.
                        Blank lines and <code>#</code> comments are ignored.]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="default_role" translate="label comment" type="text" sortOrder="80"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Default Role</label>
                    <comment><![CDATA[ACL role id assigned when no IdP group matches a rule above.
                        Leave empty to deny — an unmapped user gets no role.]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>
